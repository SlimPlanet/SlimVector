{
  "Storage": {
    "Path": "/var/lib/slimvector",
    "FlushToDisk": true,
    "MaximumSegmentsBeforeCompaction": 64
  },
  "VectorIndex": {
    "AutoHnswThreshold": 50000,
    "HybridCandidateMultiplier": 4,
    "MaximumSearchLimit": 1000
  },
  "AutoIndex": {
    "Enabled": true,
    "AllowedIndexes": [ "Flat", "Hnsw", "IvfFlat", "IvfPq", "DiskAnn" ],
    "AssessmentInterval": "00:01:00",
    "MinimumMigrationInterval": "00:15:00",
    "HysteresisRatio": 0.2,
    "MinimumRecall": 0.9,
    "MinimumPerformanceGain": 0.1,
    "ValidationSampleSize": 64,
    "HnswMinimumVectors": 10000,
    "IvfMinimumVectors": 100000,
    "PqMinimumVectors": 500000,
    "DiskAnnMemoryRatio": 0.6,
    "HighUpdateRatio": 0.1
  },
  "Hnsw": { "M": 16, "EfConstruction": 200, "EfSearch": 64 },
  "Ivf": { "ListCount": 256, "ProbeCount": 8, "TrainingIterations": 20 },
  "PQ": {
    "SubvectorCount": 8,
    "CentroidCount": 256,
    "TrainingIterations": 20,
    "RerankCandidateMultiplier": 4
  },
  "DiskAnn": {
    "Path": "/var/lib/slimvector/indexes/diskann",
    "MaxDegree": 32,
    "SearchListSize": 64,
    "BeamWidth": 4,
    "DeltaThreshold": 10000,
    "PageSize": 4096,
    "CachePages": 1024,
    "RetainedGenerations": 2
  },
  "Raft": {
    "Mode": "Cluster",
    "NodeId": "node-1",
    "PublicEndpoint": "10.0.0.11:3262",
    "PublicApiEndpoint": "http://10.0.0.11:8080",
    "Members": [ "10.0.0.11:3262", "10.0.0.12:3262", "10.0.0.13:3262" ],
    "MemberApiEndpoints": [ "http://10.0.0.11:8080", "http://10.0.0.12:8080", "http://10.0.0.13:8080" ],
    "JoinExistingCluster": false,
    "DataGroupCount": 4,
    "ElectionTimeout": "00:00:03",
    "HeartbeatInterval": "00:00:00.500",
    "SnapshotEveryEntries": 10000,
    "TransmissionBlockSize": 65536
  },
  "ClusterMembership": {
    "Enabled": true,
    "WarmupRounds": 10,
    "MaximumCatchUpLagEntries": 100,
    "MinimumVotingMembers": 3,
    "CatchUpTimeout": "00:05:00",
    "OperationTimeout": "00:02:00",
    "AutoPromote": false
  },
  "AdaptiveBatching": {
    "Enabled": true,
    "MinimumBatchSize": 1,
    "MaximumBatchSize": 256,
    "MinimumWindow": "00:00:00",
    "MaximumWindow": "00:00:00.010",
    "MaximumBatchBytes": 4194304
  },
  "Backpressure": {
    "GlobalQueueCapacity": 50000,
    "PerCollectionQueueCapacity": 5000,
    "PerShardQueueCapacity": 10000,
    "PerClientQueueCapacity": 2000,
    "MaximumConcurrentWrites": 8,
    "EnqueueTimeout": "00:00:02"
  },
  "RateLimit": {
    "Enabled": true,
    "Global": { "TokensPerSecond": 20000, "BurstCapacity": 40000 },
    "Client": { "TokensPerSecond": 2000, "BurstCapacity": 4000 },
    "Collection": { "TokensPerSecond": 5000, "BurstCapacity": 10000 },
    "Read": { "TokensPerSecond": 15000, "BurstCapacity": 30000 },
    "Write": { "TokensPerSecond": 5000, "BurstCapacity": 10000 },
    "Admin": { "TokensPerSecond": 100, "BurstCapacity": 200 },
    "ReservedReadFraction": 0.2,
    "ReservedWriteFraction": 0.1,
    "IdleBucketExpiration": "00:10:00",
    "RecoveryWindow": "00:00:30",
    "MinimumAdaptiveRateRatio": 0.1
  },
  "Observability": {
    "MetricsEnabled": true,
    "StructuredConsoleLogging": true,
    "ServiceName": "SlimVector",
    "SlowQueryThreshold": "00:00:00.500"
  }
}
