{
  "Storage": {
    "Path": "data",
    "FlushToDisk": true,
    "MaximumSegmentsBeforeCompaction": 64
  },
  "Collections": {
    "IdleTimeout": "00:15:00",
    "EvictionSweepInterval": "00:01:00",
    "MaximumOpenCollections": 128
  },
  "VectorIndex": {
    "AutoHnswThreshold": 50000,
    "HybridCandidateMultiplier": 4,
    "MaximumSearchLimit": 1000
  },
  "AutoIndex": {
    "Enabled": true,
    "AllowedIndexes": [ "Flat", "Hnsw", "IvfFlat", "IvfPq", "DiskAnn" ],
    "AssessmentInterval": "00:01:00",
    "MinimumMigrationInterval": "00:15:00",
    "HysteresisRatio": 0.2,
    "MinimumRecall": 0.9,
    "MinimumPerformanceGain": 0.1,
    "ValidationSampleSize": 64,
    "HnswMinimumVectors": 10000,
    "IvfMinimumVectors": 100000,
    "PqMinimumVectors": 500000,
    "DiskAnnMemoryRatio": 0.6,
    "HighUpdateRatio": 0.1
  },
  "Hnsw": {
    "M": 16,
    "EfConstruction": 200,
    "EfSearch": 64
  },
  "Ivf": {
    "ListCount": 256,
    "ProbeCount": 8,
    "TrainingIterations": 20
  },
  "PQ": {
    "SubvectorCount": 8,
    "CentroidCount": 256,
    "TrainingIterations": 20,
    "RerankCandidateMultiplier": 4
  },
  "DiskAnn": {
    "Path": "data/indexes/diskann",
    "MaxDegree": 32,
    "SearchListSize": 64,
    "BeamWidth": 4,
    "DeltaThreshold": 10000,
    "PageSize": 4096,
    "CachePages": 256,
    "RetainedGenerations": 2
  },
  "TextIndex": {
    "Bm25K1": 1.2,
    "Bm25B": 0.75,
    "MaximumTermsPerDocument": 100000
  },
  "MetadataIndex": {
    "IndexByDefault": true,
    "MaximumFilterDepth": 32
  },
  "Raft": {
    "Mode": "SingleNode",
    "NodeId": "node-1",
    "PublicEndpoint": "http://127.0.0.1:3262",
    "PublicApiEndpoint": "http://127.0.0.1:8080",
    "Members": [],
    "MemberApiEndpoints": [],
    "JoinExistingCluster": false,
    "DataGroupCount": 2,
    "ElectionTimeout": "00:00:02",
    "HeartbeatInterval": "00:00:00.250",
    "SnapshotEveryEntries": 10000,
    "TransmissionBlockSize": 65536
  },
  "ClusterMembership": {
    "Enabled": true,
    "WarmupRounds": 10,
    "MaximumCatchUpLagEntries": 100,
    "MinimumVotingMembers": 3,
    "CatchUpTimeout": "00:05:00",
    "OperationTimeout": "00:02:00",
    "AutoPromote": false
  },
  "GeoReplication": {
    "Enabled": false,
    "AcceptIncoming": false,
    "ReadOnlySecondary": true,
    "Mode": "Asynchronous",
    "OriginId": "primary",
    "SharedSecret": "",
    "StatePath": "data/geo-replication",
    "RetryMinimumDelay": "00:00:01",
    "RetryMaximumDelay": "00:01:00",
    "QueueCapacity": 10000,
    "RequestTimeout": "00:00:30"
  },
  "AdaptiveBatching": {
    "Enabled": true,
    "MinimumBatchSize": 1,
    "MaximumBatchSize": 256,
    "MinimumWindow": "00:00:00",
    "MaximumWindow": "00:00:00.010",
    "MaximumBatchBytes": 4194304
  },
  "Backpressure": {
    "GlobalQueueCapacity": 50000,
    "PerCollectionQueueCapacity": 5000,
    "PerShardQueueCapacity": 10000,
    "PerClientQueueCapacity": 2000,
    "MaximumConcurrentWrites": 4,
    "EnqueueTimeout": "00:00:02"
  },
  "RateLimit": {
    "Enabled": true,
    "Global": { "TokensPerSecond": 20000, "BurstCapacity": 40000 },
    "Client": { "TokensPerSecond": 2000, "BurstCapacity": 4000 },
    "Collection": { "TokensPerSecond": 5000, "BurstCapacity": 10000 },
    "Read": { "TokensPerSecond": 15000, "BurstCapacity": 30000 },
    "Write": { "TokensPerSecond": 5000, "BurstCapacity": 10000 },
    "Admin": { "TokensPerSecond": 100, "BurstCapacity": 200 },
    "ReservedReadFraction": 0.2,
    "ReservedWriteFraction": 0.1,
    "IdleBucketExpiration": "00:10:00",
    "RecoveryWindow": "00:00:30",
    "MinimumAdaptiveRateRatio": 0.1
  },
  "Backup": {
    "Enabled": false,
    "Provider": "FileSystem",
    "Path": "backups",
    "Interval": "06:00:00",
    "RetentionCount": 14,
    "Encrypt": false,
    "S3Region": "us-east-1",
    "Prefix": "slimvector"
  },
  "Api": {
    "RoutePrefix": "/api/v1",
    "MaximumBatchSize": 1000,
    "MaximumRequestBodyBytes": 16777216,
    "RequestTimeout": "00:00:30",
    "AdminEndpointsEnabled": false,
    "AdminApiKey": ""
  },
  "Observability": {
    "MetricsEnabled": true,
    "StructuredConsoleLogging": true,
    "ServiceName": "SlimVector",
    "SlowQueryThreshold": "00:00:00.500"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
