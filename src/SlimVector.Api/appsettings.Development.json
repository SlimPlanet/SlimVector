{
  "Storage": {
    "FlushToDisk": false
  },
  "AutoIndex": {
    "AssessmentInterval": "00:00:05",
    "MinimumMigrationInterval": "00:00:10",
    "HnswMinimumVectors": 100,
    "IvfMinimumVectors": 1000,
    "PqMinimumVectors": 5000
  },
  "DiskAnn": {
    "Path": "data-development/indexes/diskann",
    "DeltaThreshold": 100,
    "CachePages": 32
  },
  "RateLimit": {
    "Global": { "TokensPerSecond": 100000, "BurstCapacity": 200000 },
    "Client": { "TokensPerSecond": 10000, "BurstCapacity": 20000 }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug"
    }
  }
}
